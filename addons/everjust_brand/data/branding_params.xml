<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- Document title base used by the web client -->
        <record id="everjust_doc_title" model="ir.config_parameter">
            <field name="key">web.base.title</field>
            <field name="value">EVERJUST.APP</field>
        </record>

        <!-- PWA desktop app name (shown when installing / in the title bar) -->
        <record id="everjust_web_app_name" model="ir.config_parameter">
            <field name="key">web.web_app_name</field>
            <field name="value">EVERJUST.APP</field>
        </record>

        <!-- Apply branded company report footers on install -->
        <function model="res.company" name="_everjust_apply_defaults"/>

        <!-- Rename apps with Odoo-coined names to match the marketing site
             (Discuss→Chat, Knowledge→Wiki, Sign→Signatures, eLearning→Courses).
             Defensive: modules not installed are skipped. -->
        <function model="res.company" name="_everjust_rename_apps"/>

        <!--
            Clear the default home action so users land on the app grid
            (home menu) instead of being dumped into Discuss. The mail
            module sets action_id to Discuss on fresh databases; this
            overrides that for the admin user (uid 2) and the default
            template user (uid 1).
        -->
        <record id="base.user_admin" model="res.users">
            <field name="action_id" eval="False"/>
        </record>
        <record id="base.user_root" model="res.users">
            <field name="action_id" eval="False"/>
        </record>

    </data>
</odoo>

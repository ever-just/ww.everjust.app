<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Add Ringover as an SMS provider option + TextBee config -->
        <record id="res_config_settings_view_form" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.inherit.everjust</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="sms.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//widget[@service_name='sms']" position="after">
                    <!-- TextBee config -->
                    <div class="content-group" invisible="sms_provider != 'textbee'">
                        <div class="mt8 text-muted">
                            Self-hosted SMS gateway — no per-message cost.
                        </div>
                        <div class="mt8">
                            <button name="%(base_setup.action_general_configuration)d"
                                    icon="oi-arrow-right"
                                    type="action" class="btn-link"
                                    string="Configure TextBee Gateway URL in System Parameters"/>
                        </div>
                    </div>
                    <!-- Ringover config -->
                    <div class="content-group" invisible="sms_provider != 'ringover'">
                        <div class="mt8 text-muted">
                            Send and receive SMS through Ringover. Requires a Ringover Business plan or higher.
                        </div>
                        <div class="mt8">
                            <a class="btn-link fw-bold" href="https://www.ringover.com/apps" target="_blank">
                                <i class="oi oi-arrow-right"/>
                                Download Ringover App (iOS / Android / Desktop)
                            </a>
                        </div>
                    </div>
                </xpath>
            </field>
        </record>

        <!-- Ringover VoIP Phone setting in Contacts block -->
        <record id="res_config_settings_voip_view" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.inherit.everjust.voip</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//setting[@id='sms']" position="after">
                    <setting string="Ringover VoIP Phone"
                             help="Make and receive calls from EVERJUST.APP with Ringover. Track calls, SMS, and get AI transcripts.">
                        <div class="content-group">
                            <div class="mt8">
                                <button name="%(voip_oca.voip_pbx_act_window)d"
                                        icon="oi-arrow-right"
                                        type="action" class="btn-link"
                                        string="Configure PBX Connection"/>
                            </div>
                            <div class="mt4">
                                <a class="btn-link fw-bold"
                                   href="https://chromewebstore.google.com/detail/ringover-voip-phone-for-o/bdeapcnahigpibeoehandgaiijljkdnl"
                                   target="_blank">
                                    <i class="oi oi-arrow-right"/>
                                    Install Ringover Chrome Extension
                                </a>
                            </div>
                            <div class="mt4">
                                <a class="btn-link fw-bold"
                                   href="https://www.ringover.com/apps"
                                   target="_blank">
                                    <i class="oi oi-arrow-right"/>
                                    Download Ringover Mobile App
                                </a>
                            </div>
                        </div>
                    </setting>
                </xpath>
            </field>
        </record>
    </data>
</odoo>

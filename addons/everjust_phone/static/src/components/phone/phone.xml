<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

    <!-- Systray icon -->
    <t t-name="everjust_phone.PhoneSystray">
        <div class="ej_phone_systray">
            <button class="o_nav_entry border-0 bg-transparent"
                    title="Phone"
                    t-on-click="onClick">
                <i t-attf-class="fa fa-phone fs-5 #{phone.state.status === 'on-call' ? 'text-success' : ''}"/>
                <span t-if="phone.state.status === 'on-call'"
                      class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-success"
                      style="font-size:8px;">
                    LIVE
                </span>
            </button>
            <PhoneWidget t-if="phone.state.isOpen"/>
        </div>
    </t>

    <!-- Main softphone widget -->
    <t t-name="everjust_phone.PhoneWidget">
        <div class="ej_phone position-fixed bottom-0 end-0 mb-2 me-3 bg-white shadow-lg rounded-3 border"
             style="width:320px; z-index:1050;">

            <!-- Header -->
            <div class="ej_phone_header d-flex justify-content-between align-items-center px-3 py-2 bg-dark text-white rounded-top-3">
                <div class="d-flex align-items-center gap-2">
                    <i t-attf-class="fa fa-circle small #{phone.state.status === 'ready' ? 'text-success' : phone.state.status === 'on-call' ? 'text-warning' : 'text-muted'}"/>
                    <span class="fw-bold">Phone</span>
                </div>
                <button class="btn btn-sm text-white border-0" t-on-click="() => this.phone.toggle()">
                    <i class="fa fa-times"/>
                </button>
            </div>

            <!-- Active call view -->
            <div t-if="phone.state.status === 'on-call'" class="p-4 text-center">
                <div class="text-muted small" t-esc="phone.state.callDirection === 'inbound' ? 'Incoming call' : 'Calling...'"/>
                <div class="fs-4 fw-bold mt-1" t-esc="phone.state.callPartner || phone.state.callNumber"/>
                <div class="fs-5 mt-2 font-monospace" t-esc="formattedDuration"/>
                <div class="d-flex justify-content-center gap-3 mt-3">
                    <button class="btn btn-outline-secondary rounded-circle"
                            style="width:50px;height:50px;"
                            t-att-class="{'btn-warning': phone.state.isMuted}"
                            t-on-click="onToggleMute"
                            title="Mute">
                        <i t-attf-class="fa #{phone.state.isMuted ? 'fa-microphone-slash' : 'fa-microphone'}"/>
                    </button>
                    <button class="btn btn-danger rounded-circle"
                            style="width:50px;height:50px;"
                            t-on-click="onHangup"
                            title="Hang up">
                        <i class="fa fa-phone fa-rotate-135"/>
                    </button>
                </div>
                <!-- DTMF pad during call -->
                <div class="mt-3">
                    <div class="row g-1 justify-content-center" style="max-width:180px;margin:auto;">
                        <t t-foreach="['1','2','3','4','5','6','7','8','9','*','0','#']" t-as="d" t-key="d">
                            <div class="col-4">
                                <button class="btn btn-outline-dark w-100 py-2"
                                        t-on-click="() => this.onDialDigit(d)"
                                        t-esc="d"/>
                            </div>
                        </t>
                    </div>
                </div>
            </div>

            <!-- Normal view (not on call) -->
            <div t-else="">
                <!-- Tabs -->
                <ul class="nav nav-tabs nav-fill px-2 pt-2">
                    <li class="nav-item">
                        <a t-attf-class="nav-link small py-1 #{phone.state.activeTab === 'dialer' ? 'active' : ''}"
                           href="#" t-on-click.prevent="() => this.onSelectTab('dialer')">
                            Dialer
                        </a>
                    </li>
                    <li class="nav-item">
                        <a t-attf-class="nav-link small py-1 #{phone.state.activeTab === 'history' ? 'active' : ''}"
                           href="#" t-on-click.prevent="() => this.onSelectTab('history')">
                            Recent
                        </a>
                    </li>
                </ul>

                <!-- Dialer tab -->
                <div t-if="phone.state.activeTab === 'dialer'" class="p-3">
                    <div class="input-group mb-3">
                        <input type="tel" class="form-control text-center fs-5 font-monospace"
                               placeholder="Enter number"
                               t-model="dialInput.value"
                               t-on-keydown="(ev) => ev.key === 'Enter' &amp;&amp; this.onCall()"/>
                        <button class="btn btn-outline-secondary" t-on-click="onBackspace" title="Delete">
                            <i class="fa fa-arrow-left"/>
                        </button>
                    </div>
                    <!-- Numpad -->
                    <div class="row g-1 mb-3" style="max-width:220px;margin:auto;">
                        <t t-foreach="['1','2','3','4','5','6','7','8','9','*','0','#']" t-as="d" t-key="d">
                            <div class="col-4">
                                <button class="btn btn-outline-dark w-100 py-2 fs-5"
                                        t-on-click="() => this.onDialDigit(d)"
                                        t-esc="d"/>
                            </div>
                        </t>
                    </div>
                    <button class="btn btn-success w-100 py-2 fs-5"
                            t-on-click="onCall"
                            t-att-disabled="!dialInput.value.trim()">
                        <i class="fa fa-phone me-2"/>Call
                    </button>
                </div>

                <!-- History tab -->
                <div t-if="phone.state.activeTab === 'history'" class="p-2" style="max-height:350px;overflow-y:auto;">
                    <div t-if="!phone.state.recentCalls.length" class="text-center text-muted py-4">
                        No recent calls
                    </div>
                    <div t-foreach="phone.state.recentCalls" t-as="call" t-key="call.id"
                         class="d-flex align-items-center gap-2 p-2 border-bottom cursor-pointer"
                         t-on-click="() => this.onCallFromHistory(call)">
                        <i t-attf-class="fa #{call.direction === 'inbound' ? 'fa-arrow-down text-primary' : 'fa-arrow-up text-success'}"/>
                        <div class="flex-grow-1">
                            <div class="small fw-medium" t-esc="call.display_name"/>
                            <div class="text-muted" style="font-size:11px;">
                                <span t-esc="call.status"/>
                                <span t-if="call.duration"> · <t t-esc="Math.floor(call.duration/60)"/>m <t t-esc="call.duration%60"/>s</span>
                            </div>
                        </div>
                        <a t-if="call.recording_url" t-att-href="call.recording_url"
                           target="_blank" class="btn btn-sm btn-outline-secondary" title="Recording">
                            <i class="fa fa-play"/>
                        </a>
                    </div>
                </div>
            </div>

            <!-- Status bar -->
            <div class="ej_phone_footer px-3 py-1 border-top text-muted d-flex justify-content-between" style="font-size:11px;">
                <span t-esc="phone.state.status"/>
                <span t-if="phone.state.identity" t-esc="phone.state.identity"/>
            </div>
        </div>
    </t>

</templates>

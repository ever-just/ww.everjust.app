<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Replace the login page brand with EVERJUST.APP -->
    <template id="everjust_login_brand" inherit_id="web.login_layout">
        <!-- Swap the upstream company logo for the EVERJUST.APP wordmark -->
        <xpath expr="//img" position="replace">
            <h1 class="everjust-wordmark">EVERJUST.APP</h1>
        </xpath>
        <!-- Remove the "Powered by Odoo" footer link -->
        <xpath expr="//a[contains(@href, 'odoo.com')]" position="replace"/>
    </template>

</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Appointment Booking: List View -->
    <record id="appointment_booking_view_list" model="ir.ui.view">
        <field name="name">appointment.booking.list</field>
        <field name="model">appointment.booking</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'confirmed'" decoration-muted="state == 'cancelled'" decoration-info="state == 'done'">
                <field name="name"/>
                <field name="appointment_type_id"/>
                <field name="partner_id"/>
                <field name="staff_user_id"/>
                <field name="start_datetime"/>
                <field name="end_datetime"/>
                <field name="phone"/>
                <field name="email"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'confirmed'"
                       decoration-info="state == 'done'"
                       decoration-danger="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <!-- Appointment Booking: Form View -->
    <record id="appointment_booking_view_form" model="ir.ui.view">
        <field name="name">appointment.booking.form</field>
        <field name="model">appointment.booking</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" string="Confirm" type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_done" string="Mark Done" type="object"
                            invisible="state != 'confirmed'"/>
                    <button name="action_cancel" string="Cancel" type="object"
                            invisible="state in ('done', 'cancelled')"/>
                    <button name="action_reset_draft" string="Reset to Draft" type="object"
                            invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="appointment_type_id"/>
                            <field name="partner_id"/>
                            <field name="staff_user_id"/>
                            <field name="lead_id" invisible="not lead_id"/>
                        </group>
                        <group>
                            <field name="start_datetime"/>
                            <field name="end_datetime"/>
                            <field name="duration"/>
                            <field name="location"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="email"/>
                            <field name="phone"/>
                        </group>
                        <group>
                            <field name="calendar_event_id" invisible="not calendar_event_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes">
                            <field name="notes" placeholder="Customer notes..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Appointment Booking: Calendar View -->
    <record id="appointment_booking_view_calendar" model="ir.ui.view">
        <field name="name">appointment.booking.calendar</field>
        <field name="model">appointment.booking</field>
        <field name="arch" type="xml">
            <calendar date_start="start_datetime" date_stop="end_datetime" color="color" mode="week">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="staff_user_id"/>
                <field name="state"/>
            </calendar>
        </field>
    </record>

    <!-- Appointment Booking: Search View -->
    <record id="appointment_booking_view_search" model="ir.ui.view">
        <field name="name">appointment.booking.search</field>
        <field name="model">appointment.booking</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="staff_user_id"/>
                <field name="appointment_type_id"/>
                <field name="email"/>
                <field name="phone"/>
                <filter name="draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <filter name="confirmed" string="Confirmed" domain="[('state', '=', 'confirmed')]"/>
                <filter name="done" string="Done" domain="[('state', '=', 'done')]"/>
                <filter name="cancelled" string="Cancelled" domain="[('state', '=', 'cancelled')]"/>
                <separator/>
                <filter name="today" string="Today" domain="[('start_datetime', '&gt;=', datetime.datetime.combine(context_today(), datetime.time(0,0,0))), ('start_datetime', '&lt;', datetime.datetime.combine(context_today() + relativedelta(days=1), datetime.time(0,0,0)))]"/>
                <filter name="this_week" string="This Week" domain="[('start_datetime', '&gt;=', (context_today() - relativedelta(weekday=0, weeks=1)).strftime('%%Y-%%m-%%d')), ('start_datetime', '&lt;', (context_today() + relativedelta(weekday=0)).strftime('%%Y-%%m-%%d'))]"/>
                <group>
                    <filter name="group_type" string="Appointment Type" context="{'group_by': 'appointment_type_id'}"/>
                    <filter name="group_staff" string="Staff Member" context="{'group_by': 'staff_user_id'}"/>
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Appointment Booking: Action -->
    <record id="action_appointment_booking" model="ir.actions.act_window">
        <field name="name">Bookings</field>
        <field name="res_model">appointment.booking</field>
        <field name="view_mode">list,form,calendar</field>
        <field name="context">{'search_default_confirmed': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No bookings yet
            </p>
            <p>
                Bookings appear here when customers schedule appointments
                through the website or when you create them manually.
            </p>
        </field>
    </record>

</odoo>

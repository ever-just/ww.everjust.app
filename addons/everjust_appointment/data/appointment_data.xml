        <field name="weekday">3</field>
        <field name="start_hour">9.0</field>
        <field name="end_hour">17.0</field>
    </record>
    <record id="slot_estimate_fri" model="appointment.slot">
        <field name="appointment_type_id" ref="appointment_type_estimate"/>
        <field name="weekday">4</field>
        <field name="start_hour">9.0</field>
        <field name="end_hour">17.0</field>
    </record>

    <!-- Follow-Up Meeting slots -->
    <record id="slot_followup_mon" model="appointment.slot">
        <field name="appointment_type_id" ref="appointment_type_followup"/>
        <field name="weekday">0</field>
        <field name="start_hour">9.0</field>
        <field name="end_hour">17.0</field>
    </record>
    <record id="slot_followup_tue" model="appointment.slot">
        <field name="appointment_type_id" ref="appointment_type_followup"/>
        <field name="weekday">1</field>
        <field name="start_hour">9.0</field>
        <field name="end_hour">17.0</field>
    </record>
    <record id="slot_followup_wed" model="appointment.slot">
        <field name="appointment_type_id" ref="appointment_type_followup"/>
        <field name="weekday">2</field>
        <field name="start_hour">9.0</field>
        <field name="end_hour">17.0</field>
    </record>
    <record id="slot_followup_thu" model="appointment.slot">
        <field name="appointment_type_id" ref="appointment_type_followup"/>
        <field name="weekday">3</field>
        <field name="start_hour">9.0</field>
        <field name="end_hour">17.0</field>
    </record>
    <record id="slot_followup_fri" model="appointment.slot">
        <field name="appointment_type_id" ref="appointment_type_followup"/>
        <field name="weekday">4</field>
        <field name="start_hour">9.0</field>
        <field name="end_hour">17.0</field>
    </record>

</odoo>

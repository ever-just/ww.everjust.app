<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="mail_template_booking_confirmation" model="mail.template">
        <field name="name">Appointment: Booking Confirmation</field>
        <field name="model_id" ref="everjust_appointment.model_appointment_booking"/>
        <field name="subject">Your appointment is confirmed — {{ object.appointment_type_id.name }}</field>
        <field name="email_from">{{ (object.staff_user_id.email_formatted or object.staff_user_id.company_id.email_formatted or '') }}</field>
        <field name="email_to">{{ object.email or (object.partner_id.email or '') }}</field>
        <field name="body_html"><![CDATA[
<div style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; max-width: 600px; margin: 0 auto; padding: 24px; color: #1a1a1a;">
    <h2 style="margin: 0 0 16px; font-size: 22px; font-weight: 600;">Appointment confirmed</h2>

    <p style="margin: 0 0 24px; font-size: 15px; line-height: 1.5;">
        Hi <t t-out="object.partner_id.name or 'there'">there</t>,
    </p>

    <p style="margin: 0 0 24px; font-size: 15px; line-height: 1.5;">
        Your appointment has been confirmed. Here are the details:
    </p>

    <table style="width: 100%; border-collapse: collapse; margin: 0 0 24px; font-size: 14px;">
        <tr>
            <td style="padding: 10px 12px; border-bottom: 1px solid #e5e5e5; font-weight: 600; width: 140px;">Type</td>
            <td style="padding: 10px 12px; border-bottom: 1px solid #e5e5e5;"><t t-out="object.appointment_type_id.name">Consultation</t></td>
        </tr>
        <tr>
            <td style="padding: 10px 12px; border-bottom: 1px solid #e5e5e5; font-weight: 600;">Date &amp; Time</td>
            <td style="padding: 10px 12px; border-bottom: 1px solid #e5e5e5;">
                <t t-out="format_datetime(object.start_datetime, dt_format='EEEE, MMMM d, yyyy')">Monday, January 1, 2026</t>
                at <t t-out="format_datetime(object.start_datetime, dt_format='h:mm a')">9:00 AM</t>
            </td>
        </tr>
        <tr>
            <td style="padding: 10px 12px; border-bottom: 1px solid #e5e5e5; font-weight: 600;">Duration</td>
            <td style="padding: 10px 12px; border-bottom: 1px solid #e5e5e5;">
                <t t-out="object.appointment_type_id.duration">1</t> hour(s)
            </td>
        </tr>
        <tr t-if="object.address">
            <td style="padding: 10px 12px; border-bottom: 1px solid #e5e5e5; font-weight: 600;">Service Address</td>
            <td style="padding: 10px 12px; border-bottom: 1px solid #e5e5e5;"><t t-out="object.address">123 Main St</t></td>
        </tr>
        <tr t-if="object.location">
            <td style="padding: 10px 12px; border-bottom: 1px solid #e5e5e5; font-weight: 600;">Location</td>
            <td style="padding: 10px 12px; border-bottom: 1px solid #e5e5e5;"><t t-out="object.location">Phone</t></td>
        </tr>
        <tr t-if="object.staff_user_id">
            <td style="padding: 10px 12px; border-bottom: 1px solid #e5e5e5; font-weight: 600;">With</td>
            <td style="padding: 10px 12px; border-bottom: 1px solid #e5e5e5;"><t t-out="object.staff_user_id.name">Staff</t></td>
        </tr>
    </table>

    <t t-if="object.notes">
        <p style="margin: 0 0 8px; font-size: 13px; font-weight: 600;">Your notes:</p>
        <p style="margin: 0 0 24px; font-size: 13px; color: #555; background: #f5f5f5; padding: 12px; border-radius: 6px;">
            <t t-out="object.notes">Notes</t>
        </p>
    </t>

    <p style="margin: 0; font-size: 13px; color: #888; line-height: 1.5;">
        If you need to make changes, please contact us directly.
    </p>
</div>
]]></field>
        <field name="auto_delete" eval="True"/>
        <field name="lang">{{ object.partner_id.lang }}</field>
    </record>

</odoo>

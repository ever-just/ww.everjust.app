<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inject Google Fonts into page <head> for guaranteed loading on all frontend pages -->
    <template id="tcsw_head_fonts" inherit_id="web.layout" name="TCSW — Google Fonts">
        <xpath expr="//head" position="inside">
            <link rel="preconnect" href="https://fonts.googleapis.com"/>
            <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous"/>
            <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&amp;family=Space+Grotesk:wght@400;500;600;700&amp;display=swap"/>
        </xpath>
    </template>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="phone_call_list_view" model="ir.ui.view">
        <field name="name">everjust.phone.call.list</field>
        <field name="model">everjust.phone.call</field>
        <field name="arch" type="xml">
            <list create="false">
                <field name="start_time"/>
                <field name="direction"/>
                <field name="from_number"/>
                <field name="to_number"/>
                <field name="partner_id"/>
                <field name="status"/>
                <field name="duration" string="Dur (s)"/>
                <field name="recording_url" widget="url" string="Recording"/>
                <field name="user_id"/>
            </list>
        </field>
    </record>

    <record id="phone_call_form_view" model="ir.ui.view">
        <field name="name">everjust.phone.call.form</field>
        <field name="model">everjust.phone.call</field>
        <field name="arch" type="xml">
            <form create="false" edit="false">
                <sheet>
                    <group>
                        <group string="Call">
                            <field name="direction"/>
                            <field name="from_number"/>
                            <field name="to_number"/>
                            <field name="status"/>
                            <field name="start_time"/>
                            <field name="end_time"/>
                            <field name="duration"/>
                        </group>
                        <group string="Links">
                            <field name="partner_id"/>
                            <field name="user_id"/>
                            <field name="recording_url" widget="url"/>
                            <field name="call_sid"/>
                        </group>
                    </group>
                    <group string="Transcription" invisible="not transcription">
                        <field name="transcription" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="phone_call_search_view" model="ir.ui.view">
        <field name="name">everjust.phone.call.search</field>
        <field name="model">everjust.phone.call</field>
        <field name="arch" type="xml">
            <search>
                <field name="from_number"/>
                <field name="to_number"/>
                <field name="partner_id"/>
                <filter name="inbound" string="Inbound" domain="[('direction','=','inbound')]"/>
                <filter name="outbound" string="Outbound" domain="[('direction','=','outbound')]"/>
                <filter name="completed" string="Completed" domain="[('status','=','completed')]"/>
                <filter name="missed" string="Missed" domain="[('status','in',['no-answer','busy','canceled'])]"/>
                <group>
                    <filter name="group_partner" string="Contact" context="{'group_by': 'partner_id'}"/>
                    <filter name="group_direction" string="Direction" context="{'group_by': 'direction'}"/>
                    <filter name="group_user" string="User" context="{'group_by': 'user_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="phone_call_action" model="ir.actions.act_window">
        <field name="name">Call History</field>
        <field name="res_model">everjust.phone.call</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- SMS views -->
    <record id="phone_sms_list_view" model="ir.ui.view">
        <field name="name">everjust.phone.sms.list</field>
        <field name="model">everjust.phone.sms</field>
        <field name="arch" type="xml">
            <list create="false">
                <field name="create_date" string="Date"/>
                <field name="direction"/>
                <field name="from_number"/>
                <field name="to_number"/>
                <field name="body"/>
                <field name="partner_id"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <record id="phone_sms_action" model="ir.actions.act_window">
        <field name="name">SMS Messages</field>
        <field name="res_model">everjust.phone.sms</field>
        <field name="view_mode">list</field>
    </record>
</odoo>

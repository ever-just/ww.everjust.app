<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Backend "Powered by" promotion message -> EVERJUST.APP -->
    <template id="everjust_brand_promotion" inherit_id="web.brand_promotion_message" optional="enabled">
        <xpath expr="." position="replace">
            <t t-name="web.brand_promotion_message">
                <span class="o_brand_promotion">
                    <a href="https://everjust.app" target="_blank">EVERJUST.APP</a>
                </span>
            </t>
        </xpath>
    </template>

    <!-- Replace Odoo apple-touch-icon in the backend webclient -->
    <template id="everjust_webclient_icons" inherit_id="web.webclient_bootstrap">
        <xpath expr="//link[@rel='apple-touch-icon']" position="replace">
            <link rel="apple-touch-icon" href="/everjust_brand/static/img/apple-touch-icon.png"/>
        </xpath>
    </template>

</odoo>

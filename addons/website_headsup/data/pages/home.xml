<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="hu_homepage" inherit_id="website.homepage" name="HeadsUp Homepage">
        <xpath expr="//div[@id='wrap']" position="replace">
            <div id="wrap" class="oe_structure oe_empty">

                <section class="hu-hero" data-name="Hero">
                    <div class="container">
                        <div class="row align-items-center">
                            <div class="col-lg-7">
                                <h1>Professional Lawn Care &amp; Landscaping</h1>
                                <p class="lead">
                                    Reliable outdoor services for homes and businesses
                                    in Shakopee and the Twin Cities metro.
                                </p>
                                <div class="d-flex gap-3 flex-wrap mt-4">
                                    <a href="/contactus" class="btn btn-light btn-lg" style="color: #166A0B; font-weight: 700; border-radius: 8px;">Get a Free Quote</a>
                                    <a href="/services" class="btn btn-outline-light btn-lg" style="border-radius: 8px; font-weight: 600;">Our Services</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="hu-section" data-name="Services">
                    <div class="container text-center">
                        <h2 class="hu-section-title hu-reveal">What We Do</h2>
                        <p class="hu-section-subtitle hu-reveal">
                            From weekly mowing to full landscape design — we keep your property looking its best year-round.
                        </p>
                        <div class="row g-4">
                            <div class="col-md-4 hu-reveal"><div class="hu-card"><div class="hu-card-icon"><i class="fa fa-leaf"/></div><h3>Lawn Mowing</h3><p>Weekly and bi-weekly mowing, trimming, edging, and blowing.</p></div></div>
                            <div class="col-md-4 hu-reveal"><div class="hu-card"><div class="hu-card-icon"><i class="fa fa-tree"/></div><h3>Landscaping</h3><p>Design, installation, and maintenance of gardens, beds, and hardscape.</p></div></div>
                            <div class="col-md-4 hu-reveal"><div class="hu-card"><div class="hu-card-icon"><i class="fa fa-snowflake-o"/></div><h3>Snow Removal</h3><p>Commercial and residential plowing, salting, and sidewalk clearing.</p></div></div>
                            <div class="col-md-4 hu-reveal"><div class="hu-card"><div class="hu-card-icon"><i class="fa fa-sun-o"/></div><h3>Spring Cleanup</h3><p>Debris removal, bed prep, mulching, and turf renovation.</p></div></div>
                            <div class="col-md-4 hu-reveal"><div class="hu-card"><div class="hu-card-icon"><i class="fa fa-pagelines"/></div><h3>Fall Cleanup</h3><p>Leaf removal, gutter cleaning, and winterization.</p></div></div>
                            <div class="col-md-4 hu-reveal"><div class="hu-card"><div class="hu-card-icon"><i class="fa fa-tint"/></div><h3>Irrigation</h3><p>Sprinkler install, repair, seasonal startup and blowout.</p></div></div>
                        </div>
                    </div>
                </section>

                <section class="hu-stats" data-name="Stats">
                    <div class="container">
                        <div class="row text-center g-4">
                            <div class="col-6 col-md-3 hu-reveal"><div class="hu-stat-number">150+</div><div class="hu-stat-label">Properties Served</div></div>
                            <div class="col-6 col-md-3 hu-reveal"><div class="hu-stat-number">5+</div><div class="hu-stat-label">Years in Business</div></div>
                            <div class="col-6 col-md-3 hu-reveal"><div class="hu-stat-number">4.9</div><div class="hu-stat-label">Google Rating</div></div>
                            <div class="col-6 col-md-3 hu-reveal"><div class="hu-stat-number">100%</div><div class="hu-stat-label">Satisfaction Guarantee</div></div>
                        </div>
                    </div>
                </section>

                <section class="hu-section" data-name="Why Us">
                    <div class="container">
                        <div class="row align-items-center g-5">
                            <div class="col-lg-6 hu-reveal">
                                <h2 class="hu-section-title">Why Choose Heads Up?</h2>
                                <ul class="list-unstyled mt-4" style="font-size: 1.05rem;">
                                    <li class="mb-3 d-flex align-items-start"><i class="fa fa-check-circle text-success me-3 mt-1"/><span><strong>Reliable scheduling</strong> — we show up when we say we will.</span></li>
                                    <li class="mb-3 d-flex align-items-start"><i class="fa fa-check-circle text-success me-3 mt-1"/><span><strong>Licensed &amp; insured</strong> — full coverage for your peace of mind.</span></li>
                                    <li class="mb-3 d-flex align-items-start"><i class="fa fa-check-circle text-success me-3 mt-1"/><span><strong>Local team</strong> — we live and work in the Twin Cities community.</span></li>
                                    <li class="mb-3 d-flex align-items-start"><i class="fa fa-check-circle text-success me-3 mt-1"/><span><strong>Transparent pricing</strong> — no hidden fees, free estimates.</span></li>
                                </ul>
                            </div>
                            <div class="col-lg-6 hu-reveal">
                                <div class="hu-testimonial">
                                    <div class="hu-quote">"Heads Up has maintained our commercial property for three years. They're consistent, professional, and always go the extra mile."</div>
                                    <div class="hu-author">Local Business Owner</div>
                                    <div class="hu-role">Shakopee, MN</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="hu-cta" data-name="CTA">
                    <div class="container hu-reveal">
                        <h2>Ready to get started?</h2>
                        <p>Request a free, no-obligation quote today. We typically respond within 24 hours.</p>
                        <a href="/contactus" class="btn btn-light btn-lg">Get Your Free Quote</a>
                    </div>
                </section>

            </div>
        </xpath>
    </template>
</odoo>

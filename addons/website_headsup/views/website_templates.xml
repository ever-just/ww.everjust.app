<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ─── Google Fonts preconnect ───────────────────────────── -->
    <template id="hu_fonts_preconnect" inherit_id="web.layout" name="HeadsUp Fonts">
        <xpath expr="//head/meta[@charset]" position="after">
            <link rel="preconnect" href="https://fonts.googleapis.com"/>
            <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin=""/>
        </xpath>
    </template>

    <!-- ─── Footer ────────────────────────────────────────────── -->
    <template id="hu_footer" inherit_id="website.footer_default" name="HeadsUp Footer">
        <xpath expr="//footer" position="replace">
            <footer class="oe_structure" data-name="Footer" style="background-color: #0E4507; color: #fff;">
                <div class="container py-5">
                    <div class="row g-4">
                        <!-- Brand -->
                        <div class="col-lg-4 mb-3">
                            <h5 class="fw-bold mb-3">Heads Up Outdoor Services</h5>
                            <p class="small" style="opacity: 0.8;">
                                Professional lawn care, landscaping, and outdoor
                                maintenance for residential and commercial properties
                                in the Twin Cities.
                            </p>
                        </div>
                        <!-- Quick Links -->
                        <div class="col-lg-2 col-6">
                            <h6 class="fw-bold mb-3">Company</h6>
                            <ul class="list-unstyled small">
                                <li class="mb-2"><a href="/" class="text-white text-decoration-none">Home</a></li>
                                <li class="mb-2"><a href="/services" class="text-white text-decoration-none">Services</a></li>
                                <li class="mb-2"><a href="/about" class="text-white text-decoration-none">About</a></li>
                                <li class="mb-2"><a href="/contactus" class="text-white text-decoration-none">Contact</a></li>
                            </ul>
                        </div>
                        <!-- Services -->
                        <div class="col-lg-3 col-6">
                            <h6 class="fw-bold mb-3">Services</h6>
                            <ul class="list-unstyled small">
                                <li class="mb-2" style="opacity: 0.8;">Lawn Mowing</li>
                                <li class="mb-2" style="opacity: 0.8;">Landscaping</li>
                                <li class="mb-2" style="opacity: 0.8;">Snow Removal</li>
                                <li class="mb-2" style="opacity: 0.8;">Spring/Fall Cleanup</li>
                            </ul>
                        </div>
                        <!-- Contact -->
                        <div class="col-lg-3">
                            <h6 class="fw-bold mb-3">Get in Touch</h6>
                            <ul class="list-unstyled small">
                                <li class="mb-2" style="opacity: 0.8;">
                                    <i class="fa fa-map-marker me-2"/>Shakopee, MN
                                </li>
                                <li class="mb-2">
                                    <a href="/contactus" class="text-white text-decoration-none">
                                        <i class="fa fa-envelope me-2"/>Request a Quote
                                    </a>
                                </li>
                            </ul>
                        </div>
                    </div>
                    <hr style="border-color: rgba(255,255,255,0.15);"/>
                    <div class="d-flex flex-wrap justify-content-between align-items-center small" style="opacity: 0.7;">
                        <span>Powered by EVERJUST.APP</span>
                        <span t-esc="'%s Heads Up Outdoor Services' % datetime.date.today().year"/>
                    </div>
                </div>
            </footer>
        </xpath>
    </template>

</odoo>

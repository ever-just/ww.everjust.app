# EVERJUST.APP environment configuration
# Copy to .env and fill in real values. NEVER commit .env.

# ── Database ──────────────────────────────────────────────
POSTGRES_USER=everjust
POSTGRES_PASSWORD=change_me_strong
POSTGRES_DB=control

# ── Odoo ──────────────────────────────────────────────────
ODOO_MASTER_PASSWORD=change_me_master
# dbfilter routes <subdomain>.everjust.app -> database <subdomain>
ODOO_DBFILTER=^%d$

# ── Domain ────────────────────────────────────────────────
BASE_DOMAIN=everjust.app
PLATFORM_HOST=everjust.app

# ── Analytics (optional, cookieless) ──────────────────────
# Set ANALYTICS_DOMAIN to the site domain registered in a (hosted or
# self-hosted) Plausible-compatible instance to switch on cookieless,
# privacy-first analytics. Leave blank to emit no analytics at all.
ANALYTICS_DOMAIN=
ANALYTICS_SRC=https://plausible.io/js/script.js
WILDCARD_HOST=*.everjust.app

# ── Stripe (LIVE) ─────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_ID=price_1TflJNKL0p3ve1jHbCLlDNWS
STRIPE_PRODUCT_ID=prod_Uf5UgyXUPN8UpT

# ── Email (Resend) ────────────────────────────────────────
# Platform-wide outgoing mail. The key must belong to the Resend account
# where the sending domain (everjust.co) is verified. Injected into Odoo as
# the SMTP password at runtime; also used by provisioning to configure each
# new tenant. NEVER commit the real key.
RESEND_API_KEY=re_xxx
# Verified sending domain + default From address (must be on that domain)
MAIL_DOMAIN=everjust.co
EMAIL_FROM=noreply@everjust.co

# ── GoDaddy (DNS automation) ──────────────────────────────
GODADDY_API_KEY=xxx
GODADDY_API_SECRET=xxx

# ── Control plane ─────────────────────────────────────────
CONTROL_PLANE_SECRET=change_me_session_secret

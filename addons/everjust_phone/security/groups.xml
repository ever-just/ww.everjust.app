<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="privilege_phone" model="res.groups.privilege">
        <field name="name">Phone</field>
    </record>
    <record id="group_phone_user" model="res.groups">
        <field name="name">User</field>
        <field name="privilege_id" ref="privilege_phone"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>
    <record id="group_phone_admin" model="res.groups">
        <field name="name">Administrator</field>
        <field name="privilege_id" ref="privilege_phone"/>
        <field name="implied_ids" eval="[(4, ref('group_phone_user'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>
</odoo>

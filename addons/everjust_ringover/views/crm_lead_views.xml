<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Add "Call with Ringover" button to CRM lead/opportunity form -->
    <record id="view_crm_lead_form_ringover" model="ir.ui.view">
        <field name="name">crm.lead.form.inherit.ringover</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_case_form_view_leads"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_ringover_call"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-phone"
                        string="Call"
                        invisible="not phone"/>
            </xpath>
        </field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Replace the login page brand with EVERJUST.APP -->
    <template id="everjust_login_brand" inherit_id="web.login_layout">
        <xpath expr="//div[hasclass('o_login_auth')]" position="before">
            <div class="text-center mb-4 everjust-login-brand">
                <h1 class="everjust-wordmark">EVERJUST.APP</h1>
            </div>
        </xpath>
        <!-- Remove the upstream logo image if present -->
        <xpath expr="//img[hasclass('o_login_logo')]" position="replace"/>
    </template>

</odoo>
